{
	"ci": {
		"collect": {
			"url": [
				"https://staging.fraugsleeves.dev/",
				"https://staging.fraugsleeves.dev/blog",
				"https://staging.fraugsleeves.dev/blog/epoll",
				"https://staging.fraugsleeves.dev/blog/golang-context",
				"https://staging.fraugsleeves.dev/blog/libuv",
				"https://staging.fraugsleeves.dev/wayfinders",
				"https://staging.fraugsleeves.dev/wayfinders/nodejs",
				"https://staging.fraugsleeves.dev/blog?tag=polling",
				"https://staging.fraugsleeves.dev/tags"
			],
			"numberOfRuns": 3
		},
		"assert": {
			"assertMatrix": [
				{
					"matchingUrlPattern": ".*/(blog/.+|wayfinders/.+|index)\\.html",
					"assertions": {
						"categories:seo": ["error", { "minScore": 0.9 }],
						"categories:performance": [
							"error",
							{ "minScore": 0.9 }
						],
						"categories:accessibility": [
							"error",
							{ "minScore": 0.9 }
						],
						"categories:best-practices": [
							"error",
							{ "minScore": 0.9 }
						],
						"cumulative-layout-shift": [
							"error",
							{ "maxNumericValue": 0.1 }
						],
						"largest-contentful-paint": [
							"error",
							{ "maxNumericValue": 4000 }
						],
						"first-contentful-paint": [
							"error",
							{ "maxNumericValue": 2000 }
						],
						"total-blocking-time": [
							"error",
							{ "maxNumericValue": 300 }
						]
					}
				},
				{
					"matchingUrlPattern": ".*/(blog|tags|wayfinders)\\.html",
					"assertions": {
						"categories:seo": ["off", {}],
						"categories:performance": [
							"error",
							{ "minScore": 0.9 }
						],
						"categories:accessibility": [
							"error",
							{ "minScore": 0.9 }
						],
						"categories:best-practices": [
							"error",
							{ "minScore": 0.9 }
						],
						"cumulative-layout-shift": [
							"error",
							{ "maxNumericValue": 0.1 }
						],
						"largest-contentful-paint": [
							"error",
							{ "maxNumericValue": 4000 }
						],
						"first-contentful-paint": [
							"error",
							{ "maxNumericValue": 2000 }
						],
						"total-blocking-time": [
							"error",
							{ "maxNumericValue": 300 }
						]
					}
				}
			]
		},
		"upload": {
			"target": "temporary-public-storage"
		}
	}
}
