---
import "../styles/blocks/index.css";

import { WayfindersGrid } from "../components/wayfinders";
import { Searchable } from "../layouts";
---

<Searchable title="Wayfinders">
	<div class="wayfinders-page">
		<header class="wayfinders-page__header">
			<h1 class="wayfinders-page__title">Wayfinders</h1>
			<p class="wayfinders-page__quote">
				Wayfinding encompasses all of the ways in which people orient
				themselves in physical space and navigate from place to place.
			</p>
			<p class="wayfinders-page__description">
				These articles serve to provide avenues for exploring complex
				topics across a number of posts. They give you the flexibility
				to choose the order in which you want to explore a topic, while
				providing some guidelines for best practices for most. They rely
				heavily on relationships between articles.
			</p>
		</header>

		<WayfindersGrid />
	</div>
</Searchable>
