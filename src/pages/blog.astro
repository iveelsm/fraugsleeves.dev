---
import "../styles/blog-list.css";

import { BlogPosts, BlogFilterHeader } from "../components/blogs";
import TagFilter from "../components/blogs/TagFilter";
import { Standard } from "../layouts";
---

<Standard>
	<meta slot="head" name="robots" content="noindex" />
	<div class="blog-container">
		<BlogFilterHeader />
		<BlogPosts />
	</div>
	<TagFilter client:idle />
</Standard>
