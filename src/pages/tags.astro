---
import "../styles/blocks/index.css";

import { getUniqueOccurences } from "../components/tags";
import { Searchable } from "../layouts";

const uniqueTags = await getUniqueOccurences();
---

<Searchable>
	<div class="tags-page">
		<h1 class="tags-page__title">Tags</h1>
		<div class="tags-page__list">
			{
				Object.keys(uniqueTags).map((tag) => (
					<a
						href={`/blog?tag=${encodeURIComponent(tag)}`}
						class="tag-link"
					>
						<span class="tag-link__name">{tag}</span>
						<span class="tag-link__count">{uniqueTags[tag]}</span>
					</a>
				))
			}
		</div>
		{uniqueTags.length === 0 && <p class="tags-page__no-tags">No tags found.</p>}
	</div>
</Searchable>
