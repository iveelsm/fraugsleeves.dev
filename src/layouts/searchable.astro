---
import FontLoader from "astro-font-loader/FontLoader.astro";

import Rss from "../components/rss.astro";
import SEO from "../components/seo.astro";
import Body from "./body.astro";

import { IVEELSM_FONTS_FILTER, IVEELSM_FONTS_PRELOAD } from "../constants/fonts";

interface Props {
	title?: string;
	description?: string;
	image?: string;
	alt?: string;
	article?: {
		publishedTime: string;
		modifiedTime?: string;
		authors: string[];
		tags: string[];
	};
	class?: string;
}

const {
	title,
	description,
	image,
	alt,
	article,
	class: className,
} = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link
			rel="icon"
			type="image/png"
			href="/favicon-96x96.png"
			sizes="96x96"
		/>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/apple-touch-icon.png"
		/>
		<meta name="apple-mobile-web-app-title" content="fraugsleeves.dev" />
		<link rel="manifest" href="/site.webmanifest" />
		<FontLoader
			packages={["@iveelsm/fonts"]}
			filter={IVEELSM_FONTS_FILTER}
			preload={IVEELSM_FONTS_PRELOAD}
		/>
		<Rss />
		<SEO
			title={title}
			description={description}
			image={image}
			alt={alt}
			article={article}
		/>
		<slot name="head" />
	</head>
	<Body class={className}>
		<slot />
	</Body>
</html>
