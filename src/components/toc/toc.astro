---
import Entry from "./tocEntry.astro";

import { buildTree } from "./buildTree";

const { headings } = Astro.props;
const toc = buildTree(headings);
---

{
	toc && toc.length > 0 && (
		<nav class="toc__nav">
			<ul>
				{toc.map((heading) => (
					<Entry heading={heading} />
				))}
			</ul>
		</nav>
	)
}
