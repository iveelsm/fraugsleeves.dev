---
import { isActive } from "./isActive";

interface Props {
	currentPath: string;
	navItems: {
		href: string;
		exact: boolean;
		label: string;
	}[];
}

const { currentPath, navItems } = Astro.props;
---

<div class="mobile-nav" id="mobile-nav-overlay">
	<div class="mobile-nav__content">
		<nav class="mobile-nav__links">
			{
				navItems.map((item) => (
					<a
						href={item.href}
						class:list={[
							"mobile-nav__link",
							{
								"mobile-nav__link--active": isActive(
									currentPath,
									item.href,
									item.exact,
								),
							},
						]}
					>
						{item.label}
					</a>
				))
			}
		</nav>
	</div>
</div>
