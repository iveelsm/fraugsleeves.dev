---
interface Props {
	title: string;
	href: string;
	date: Date;
	description?: string;
	tags?: string[];
	showTags?: boolean;
}

const {
	title,
	href,
	date,
	description,
	tags = [],
	showTags = true,
} = Astro.props;

import { formatDate } from "../formatDate";
import { formatText } from "../formatText";
---

<li class="post-list__item" data-tags={JSON.stringify(tags)}>
	<a href={href} class="post-list__link">
		<span class="post-list__title" set:html={formatText(title)} />
		<span class="post-list__date">{formatDate(date)}</span>
	</a>
	{description && <p class="post-list__description">{description}</p>}
	{
		showTags && tags.length > 0 && (
			<div class="post-list__tags">
				{tags.map((tag: string) => (
					<a
						href={`/blog?tag=${encodeURIComponent(tag)}`}
						class="tag"
						data-tag={tag}
					>
						{tag}
					</a>
				))}
			</div>
		)
	}
</li>
