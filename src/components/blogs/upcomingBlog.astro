---
import { LogoIcon } from "../../icons";
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<div class="upcoming__image">
	<LogoIcon />
</div>
<div class="upcoming__content">
	<h1 class="upcoming__title">Coming Soon</h1>
	<p class="upcoming__message">This page is still a work in progress.</p>
	<p class="upcoming__subtitle">
		Check back later for content about <strong>{title}</strong>.
	</p>
	<div class="upcoming__actions">
		<a href="/" class="upcoming__link upcoming__link--primary"> Take me home </a>
		<a href="/blog" class="upcoming__link upcoming__link--secondary"> Browse posts </a>
	</div>
</div>
